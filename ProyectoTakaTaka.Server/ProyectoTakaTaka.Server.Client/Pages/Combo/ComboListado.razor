@page "/combos/listados"
@inject IHttpServicio http

<h3>Listado de precios de Combos</h3>

@if (combos == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="mt-3 text-muted fw-bold">Cargando combos...</p>
    </div>
}
else if (combos.Count == 0)
{
    <div class="alert alert-info">
        <strong>ℹ️ Sin combos</strong><br />
        No hay combos registrados en el sistema.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var combo in combos)
        {
            <div class="col-md-6 col-lg-4">
                <div class="combo-card h-100">
                    <div class="combo-card-icon">
                        @if (combo.NomCombo.Contains("Lunes a Jueves"))
                        {
                            <span class="icon-emoji">📦</span>
                        }
                        else if (combo.NomCombo.Contains("Viernes"))
                        {
                            <span class="icon-emoji">🎉</span>
                        }
                        else
                        {
                            <span class="icon-emoji">🎊</span>
                        }
                    </div>

                    <div class="combo-card-body">
                        <h5 class="combo-card-title">@combo.NomCombo</h5>

                        <div class="combo-card-divider"></div>

                        <div class="combo-card-price">
                            <span class="price-label">Precio</span>
                            <span class="price-amount">@combo.Precio.ToString("C", new System.Globalization.CultureInfo("es-AR"))</span>
                        </div>
                    </div>

                    <div class="combo-card-footer">
                        @if (combo.NomCombo.Contains("Lunes a Jueves"))
                        {
                            <span class="badge-day">Lunes a Jueves</span>
                        }
                        else if (combo.NomCombo.Contains("Viernes"))
                        {
                            <span class="badge-day viernes">Viernes</span>
                        }
                        else
                        {
                            <span class="badge-day findes">Findes y Feriados</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<p class="text-danger mt-4">@Mensaje</p>

@code {
    List<ListadoComboDTO>? combos;
    string Mensaje = "";

    protected override async Task OnInitializedAsync()
    {
        await LeerCombos();
    }

    private async Task LeerCombos()
    {
        var resp = await http.Get<List<ListadoComboDTO>>("api/Combos/ListadoCombos");
        if (!resp.Error)
        {
            combos = resp.Respuesta;
        }
        else
        {
            Mensaje = resp.ObtenerError();
        }
    }
}